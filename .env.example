# 7akim Voice Server v2.0 — Environment Variables
# Copy this to .env and fill in your values

# OpenAI API Key (for Whisper STT + LLM)
OPENAI_API_KEY=sk-your-openai-key-here

# ElevenLabs API Key (for TTS)
ELEVENLABS_KEY=your-elevenlabs-key-here

# ElevenLabs Voice ID (default: Sarah)
ELEVENLABS_VOICE=EXAVITQu4vr4xnSDxMaL

# Home Assistant URL (local or Cloudflare tunnel)
HA_URL=http://192.168.68.79:8123

# Home Assistant Long-Lived Access Token
HA_TOKEN=your-ha-long-lived-token-here

# LLM Model (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# Server Port (default: 5050)
SERVER_PORT=5050
